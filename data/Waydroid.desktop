[Desktop Entry]
Type=Application
Name=Waydroid
Exec=waydroid
Comment=A container-based approach to boot a full Android system
Icon=waydroid
Categories=X-WayDroid-App;Utility;
Actions=stop;initialize;
X-Purism-FormFactor=Workstation;Mobile;

[Desktop Action stop]
Name=Stop Waydroid
Exec=waydroid session stop
Icon=waydroid

[Desktop Action initialize]
Name=Initialize Waydroid
Exec=waydroid init --client
